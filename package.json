    "@vercel/blob": "^2.6.1",
    "ai": "^7.0.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
